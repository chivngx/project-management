# Copy this file to .env and fill in real values.

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# NextAuth.js — generate a strong random string for production:
#   openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"

# Public app URL (used by NextAuth for callbacks). MUST be set to the
# production origin in deploy envs (not localhost).
NEXTAUTH_URL="http://localhost:3000"

# Realtime mini-service URL (socket.io). Used by the Next.js server to emit
# events. Leave as-is for local dev (the realtime service runs on :3003).
REALTIME_URL="http://localhost:3003"
